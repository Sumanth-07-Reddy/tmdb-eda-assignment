# =============================================
# TMDB Movie Data Pipeline & EDA
# =============================================

import requests
import pandas as pd
import sqlite3
import time
from dotenv import load_dotenv
import os

# ============== Task 1: Build the Pipeline ==============

# IMPORTANT: Replace with your own TMDB API key
# Do NOT commit your real key to GitHub
API_KEY = "your_tmdb_api_key_here"   # ← Change this

# TMDB Discover Movies endpoint
url = "https://api.themoviedb.org/3/discover/movie"

params = {
    "api_key": API_KEY,
    "language": "en-US",
    "sort_by": "popularity.desc",
    "include_adult": "false",
    "page": 1
}

print("Fetching movie data from TMDB...")

movies_list = []

# Fetch at least 20 movies (we'll get 20 from one page)
response = requests.get(url, params=params)
if response.status_code == 200:
    data = response.json()
    movies_list = data.get('results', [])
    print(f"Successfully fetched {len(movies_list)} movies.")
else:
    print(f"Error: {response.status_code} - {response.text}")

# Convert to DataFrame
movies_df = pd.DataFrame(movies_list)

# Select relevant columns
movies_df = movies_df[['id', 'title', 'release_date', 'vote_average', 
                       'vote_count', 'popularity', 'genre_ids']]

# Rename id to movie_id for clarity
movies_df = movies_df.rename(columns={'id': 'movie_id'})

# Save to SQLite database
conn = sqlite3.connect('movies.db')
movies_df.to_sql('movies', conn, if_exists='replace', index=False)
conn.close()

print("Data saved to SQLite table 'movies'.")

# ============== Task 2: Perform EDA ==============

# Load back from database
conn = sqlite3.connect('movies.db')
df = pd.read_sql("SELECT * FROM movies", conn)
conn.close()

print("\n=== EDA Results ===")

# 1. Display the first 5 rows
print("First 5 rows:")
print(df.head())

# 2. Show summary statistics for numeric columns
print("\nSummary statistics:")
print(df.describe())

# 3. Count the number of movies per genre (simplified - genre_ids is list)
# For simplicity, we'll count movies with genre_ids (most have multiple)
print("\nNumber of movies with genre information:", 
      df['genre_ids'].notna().sum())

# 4. Identify columns with missing values
print("\nMissing values per column:")
print(df.isnull().sum())

# Optional: Basic genre exploration if you want to expand later
print("\nTop 5 most popular movies:")
print(df.nlargest(5, 'popularity')[['title', 'popularity']])
